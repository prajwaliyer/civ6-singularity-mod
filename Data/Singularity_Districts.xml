<?xml version="1.0" encoding="utf-8"?>
<GameData>
	<Types>
		<Row Type="DISTRICT_FUSION_REACTOR" Kind="KIND_DISTRICT"/>
		<Row Type="DISTRICT_DATA_CENTER"    Kind="KIND_DISTRICT"/>
	</Types>

	<Districts>
		<Row DistrictType="DISTRICT_FUSION_REACTOR"
			 Name="LOC_DISTRICT_FUSION_REACTOR_NAME"
			 Description="LOC_DISTRICT_FUSION_REACTOR_DESCRIPTION"
			 PrereqTech="TECH_NUCLEAR_FUSION"
			 PlunderType="PLUNDER_SCIENCE"
			 PlunderAmount="50"
			 AdvisorType="ADVISOR_GENERIC"
			 Cost="600"
			 CostProgressionModel="COST_PROGRESSION_NUM_UNDER_AVG_PLUS_TECH"
			 CostProgressionParam1="40"
			 Maintenance="3"
			 RequiresPlacement="true"
			 RequiresPopulation="true"
			 OnePerCity="true"
			 Aqueduct="false"
			 NoAdjacentCity="false"
			 InternalOnly="false"
			 ZOC="false"
			 CaptureRemovesBuildings="false"
			 CaptureRemovesCityDefenses="false"
			 MilitaryDomain="NO_DOMAIN"
			 Appeal="-1"
			 CityStrengthModifier="2"/>

		<!-- Data Center: multiple per city, yields gated by Chip stockpile -->
		<Row DistrictType="DISTRICT_DATA_CENTER"
			 Name="LOC_DISTRICT_DATA_CENTER_NAME"
			 Description="LOC_DISTRICT_DATA_CENTER_DESCRIPTION"
			 PrereqTech="TECH_COMPUTERS"
			 PlunderType="PLUNDER_SCIENCE"
			 PlunderAmount="50"
			 AdvisorType="ADVISOR_GENERIC"
			 Cost="400"
			 CostProgressionModel="COST_PROGRESSION_NUM_UNDER_AVG_PLUS_TECH"
			 CostProgressionParam1="40"
			 Maintenance="3"
			 RequiresPlacement="true"
			 RequiresPopulation="true"
			 OnePerCity="false"
			 Aqueduct="false"
			 NoAdjacentCity="false"
			 InternalOnly="false"
			 ZOC="false"
			 CaptureRemovesBuildings="false"
			 CaptureRemovesCityDefenses="false"
			 MilitaryDomain="NO_DOMAIN"
			 Appeal="-1"
			 CityStrengthModifier="2"/>
	</Districts>

	<!-- Fusion Reactor adjacency: +2 Production per adjacent Industrial Zone -->
	<District_Adjacencies>
		<Row DistrictType="DISTRICT_FUSION_REACTOR" YieldChangeId="FusionReactor_IndustrialZone_Production"/>
		<!-- Data Center adjacencies -->
		<Row DistrictType="DISTRICT_DATA_CENTER" YieldChangeId="DataCenter_DataCenter_Science"/>
		<Row DistrictType="DISTRICT_DATA_CENTER" YieldChangeId="DataCenter_Campus_Science"/>
		<Row DistrictType="DISTRICT_DATA_CENTER" YieldChangeId="DataCenter_FusionReactor_Production"/>
		<Row DistrictType="DISTRICT_DATA_CENTER" YieldChangeId="DataCenter_SolarFarm_Production"/>
		<Row DistrictType="DISTRICT_DATA_CENTER" YieldChangeId="DataCenter_Microreactor_Production"/>
	</District_Adjacencies>

	<!-- ================================================================== -->
	<!-- Data Center modifiers: chip consumption + conditional yields        -->
	<!-- ================================================================== -->

	<!-- Each Data Center consumes 1 Chip per turn (reduces extraction rate) -->
	<Modifiers>
		<Row>
			<ModifierId>DATA_CENTER_CONSUME_CHIPS</ModifierId>
			<ModifierType>MODIFIER_PLAYER_ADJUST_FREE_RESOURCE_EXTRACTION</ModifierType>
		</Row>
		<!-- Yields only active when player has Chips in stockpile -->
		<Row>
			<ModifierId>DATA_CENTER_YIELD_SCIENCE</ModifierId>
			<ModifierType>MODIFIER_PLAYER_DISTRICT_ADJUST_BASE_YIELD_CHANGE</ModifierType>
			<SubjectRequirementSetId>PLAYER_HAS_CHIPS_OWNED</SubjectRequirementSetId>
		</Row>
		<Row>
			<ModifierId>DATA_CENTER_YIELD_PRODUCTION</ModifierId>
			<ModifierType>MODIFIER_PLAYER_DISTRICT_ADJUST_BASE_YIELD_CHANGE</ModifierType>
			<SubjectRequirementSetId>PLAYER_HAS_CHIPS_OWNED</SubjectRequirementSetId>
		</Row>
	</Modifiers>

	<ModifierArguments>
		<Row><ModifierId>DATA_CENTER_CONSUME_CHIPS</ModifierId><Name>ResourceType</Name><Value>RESOURCE_CHIPS</Value></Row>
		<Row><ModifierId>DATA_CENTER_CONSUME_CHIPS</ModifierId><Name>Amount</Name><Value>-1</Value></Row>
		<Row><ModifierId>DATA_CENTER_YIELD_SCIENCE</ModifierId><Name>YieldType</Name><Value>YIELD_SCIENCE</Value></Row>
		<Row><ModifierId>DATA_CENTER_YIELD_SCIENCE</ModifierId><Name>Amount</Name><Value>5</Value></Row>
		<Row><ModifierId>DATA_CENTER_YIELD_PRODUCTION</ModifierId><Name>YieldType</Name><Value>YIELD_PRODUCTION</Value></Row>
		<Row><ModifierId>DATA_CENTER_YIELD_PRODUCTION</ModifierId><Name>Amount</Name><Value>3</Value></Row>
	</ModifierArguments>

	<DistrictModifiers>
		<Row DistrictType="DISTRICT_DATA_CENTER" ModifierId="DATA_CENTER_CONSUME_CHIPS"/>
		<Row DistrictType="DISTRICT_DATA_CENTER" ModifierId="DATA_CENTER_YIELD_SCIENCE"/>
		<Row DistrictType="DISTRICT_DATA_CENTER" ModifierId="DATA_CENTER_YIELD_PRODUCTION"/>
	</DistrictModifiers>

	<!-- Requirement: Player must have Chips in stockpile -->
	<RequirementSets>
		<Row RequirementSetId="PLAYER_HAS_CHIPS_OWNED" RequirementSetType="REQUIREMENTSET_TEST_ALL"/>
	</RequirementSets>
	<RequirementSetRequirements>
		<Row RequirementSetId="PLAYER_HAS_CHIPS_OWNED" RequirementId="REQUIRES_PLAYER_HAS_CHIPS_OWNED"/>
	</RequirementSetRequirements>
	<Requirements>
		<Row RequirementId="REQUIRES_PLAYER_HAS_CHIPS_OWNED" RequirementType="REQUIREMENT_PLAYER_HAS_RESOURCE_OWNED"/>
	</Requirements>
	<RequirementArguments>
		<Row RequirementId="REQUIRES_PLAYER_HAS_CHIPS_OWNED" Name="ResourceType" Value="RESOURCE_CHIPS"/>
	</RequirementArguments>
</GameData>
