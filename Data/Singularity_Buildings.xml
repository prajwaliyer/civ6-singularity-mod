<?xml version="1.0" encoding="utf-8"?>
<GameData>
	<Types>
		<Row Type="BUILDING_CHIP_FAB"          Kind="KIND_BUILDING"/>
		<Row Type="BUILDING_ADVANCED_CHIP_FAB"  Kind="KIND_BUILDING"/>
		<Row Type="BUILDING_EXPERT_CHIP_FAB"    Kind="KIND_BUILDING"/>
		<Row Type="BUILDING_AI_DIVIDENDS"       Kind="KIND_BUILDING"/>
		<Row Type="BUILDING_FUSION_CORE"        Kind="KIND_BUILDING"/>
		<Row Type="BUILDING_INORGANIC_CITY"     Kind="KIND_BUILDING"/>
	</Types>

	<Buildings>
		<!-- Tier 1: Chip Fab — unlocks with Computers, requires Factory -->
		<Row BuildingType="BUILDING_CHIP_FAB"
			 Name="LOC_BUILDING_CHIP_FAB_NAME"
			 Description="LOC_BUILDING_CHIP_FAB_DESCRIPTION"
			 PrereqTech="TECH_COMPUTERS"
			 PrereqDistrict="DISTRICT_INDUSTRIAL_ZONE"
			 PurchaseYield="YIELD_GOLD"
			 Cost="400"
			 Maintenance="2"
			 AdvisorType="ADVISOR_GENERIC"
			 CitizenSlots="1"/>

		<!-- Tier 2: Advanced Chip Fab — unlocks with Robotics, requires Chip Fab -->
		<Row BuildingType="BUILDING_ADVANCED_CHIP_FAB"
			 Name="LOC_BUILDING_ADVANCED_CHIP_FAB_NAME"
			 Description="LOC_BUILDING_ADVANCED_CHIP_FAB_DESCRIPTION"
			 PrereqTech="TECH_ROBOTICS"
			 PrereqDistrict="DISTRICT_INDUSTRIAL_ZONE"
			 PurchaseYield="YIELD_GOLD"
			 Cost="600"
			 Maintenance="3"
			 AdvisorType="ADVISOR_GENERIC"
			 CitizenSlots="1"/>

		<!-- Tier 3: Expert Chip Fab — unlocks with Nanotechnology, requires Advanced Chip Fab -->
		<Row BuildingType="BUILDING_EXPERT_CHIP_FAB"
			 Name="LOC_BUILDING_EXPERT_CHIP_FAB_NAME"
			 Description="LOC_BUILDING_EXPERT_CHIP_FAB_DESCRIPTION"
			 PrereqTech="TECH_NANOTECHNOLOGY"
			 PrereqDistrict="DISTRICT_INDUSTRIAL_ZONE"
			 PurchaseYield="YIELD_GOLD"
			 Cost="800"
			 Maintenance="4"
			 AdvisorType="ADVISOR_GENERIC"
			 CitizenSlots="1"/>

		<!-- AI Dividends — Commercial Hub building, +10 Gold -->
		<Row BuildingType="BUILDING_AI_DIVIDENDS"
			 Name="LOC_BUILDING_AI_DIVIDENDS_NAME"
			 Description="LOC_BUILDING_AI_DIVIDENDS_DESCRIPTION"
			 PrereqTech="TECH_COMPUTERS"
			 PrereqDistrict="DISTRICT_COMMERCIAL_HUB"
			 PurchaseYield="YIELD_GOLD"
			 Cost="400"
			 Maintenance="2"
			 AdvisorType="ADVISOR_GENERIC"
			 CitizenSlots="1"/>

		<!-- Fusion Core — built inside Fusion Reactor district, provides Power -->
		<Row BuildingType="BUILDING_FUSION_CORE"
			 Name="LOC_BUILDING_FUSION_CORE_NAME"
			 Description="LOC_BUILDING_FUSION_CORE_DESCRIPTION"
			 PrereqTech="TECH_NUCLEAR_FUSION"
			 PrereqDistrict="DISTRICT_FUSION_REACTOR"
			 PurchaseYield="YIELD_GOLD"
			 Cost="300"
			 Maintenance="2"
			 AdvisorType="ADVISOR_GENERIC"
			 CitizenSlots="1"
			 RegionalRange="6"/>

		<!-- Invisible marker: granted when Convert to Inorganic Life completes.
			 Prevents the project from appearing again in this city. -->
		<Row BuildingType="BUILDING_INORGANIC_CITY"
			 Name="LOC_BUILDING_INORGANIC_CITY_NAME"
			 Description="LOC_BUILDING_INORGANIC_CITY_DESCRIPTION"
			 PrereqDistrict="DISTRICT_CITY_CENTER"
			 Cost="0"
			 InternalOnly="true"/>
	</Buildings>

	<!-- Build chain: Chip Fab → Advanced → Expert -->
	<BuildingPrereqs>
		<Row Building="BUILDING_ADVANCED_CHIP_FAB" PrereqBuilding="BUILDING_CHIP_FAB"/>
		<Row Building="BUILDING_EXPERT_CHIP_FAB"   PrereqBuilding="BUILDING_ADVANCED_CHIP_FAB"/>
	</BuildingPrereqs>

	<!-- Chip Fab buildings produce Chips (strategic resource) per turn -->
	<!-- Incremental: +1, +2, +2 so totals are 1/3/5 per city -->
	<!-- Only produces when the player has improved Silicon -->
	<Modifiers>
		<!-- Kill food-based growth in cities converted to Inorganic Life (-100%) -->
		<Row>
			<ModifierId>INORGANIC_CITY_NO_FOOD_GROWTH</ModifierId>
			<ModifierType>MODIFIER_SINGLE_CITY_ADJUST_CITY_GROWTH</ModifierType>
		</Row>
		<!-- Chip Fab resource production (requires improved Silicon) -->
		<Row>
			<ModifierId>CHIP_FAB_PRODUCE_CHIPS</ModifierId>
			<ModifierType>MODIFIER_PLAYER_ADJUST_FREE_RESOURCE_EXTRACTION</ModifierType>
			<SubjectRequirementSetId>PLAYER_HAS_IMPROVED_SILICON</SubjectRequirementSetId>
		</Row>
		<Row>
			<ModifierId>ADVANCED_CHIP_FAB_PRODUCE_CHIPS</ModifierId>
			<ModifierType>MODIFIER_PLAYER_ADJUST_FREE_RESOURCE_EXTRACTION</ModifierType>
			<SubjectRequirementSetId>PLAYER_HAS_IMPROVED_SILICON</SubjectRequirementSetId>
		</Row>
		<Row>
			<ModifierId>EXPERT_CHIP_FAB_PRODUCE_CHIPS</ModifierId>
			<ModifierType>MODIFIER_PLAYER_ADJUST_FREE_RESOURCE_EXTRACTION</ModifierType>
			<SubjectRequirementSetId>PLAYER_HAS_IMPROVED_SILICON</SubjectRequirementSetId>
		</Row>
		<!-- Fusion Core: 16 free Power -->
		<Row>
			<ModifierId>FUSION_CORE_GENERATE_POWER</ModifierId>
			<ModifierType>MODIFIER_SINGLE_CITY_ADJUST_FREE_POWER</ModifierType>
		</Row>
	</Modifiers>

	<!-- Requirement: Player must have at least one improved Silicon tile -->
	<RequirementSets>
		<Row RequirementSetId="PLAYER_HAS_IMPROVED_SILICON" RequirementSetType="REQUIREMENTSET_TEST_ALL"/>
	</RequirementSets>
	<RequirementSetRequirements>
		<Row RequirementSetId="PLAYER_HAS_IMPROVED_SILICON" RequirementId="REQUIRES_PLAYER_HAS_IMPROVED_SILICON"/>
	</RequirementSetRequirements>
	<Requirements>
		<Row RequirementId="REQUIRES_PLAYER_HAS_IMPROVED_SILICON" RequirementType="REQUIREMENT_PLAYER_HAS_RESOURCE_IMPROVED"/>
	</Requirements>
	<RequirementArguments>
		<Row RequirementId="REQUIRES_PLAYER_HAS_IMPROVED_SILICON" Name="ResourceType" Value="RESOURCE_SILICON"/>
	</RequirementArguments>

	<ModifierArguments>
		<Row><ModifierId>INORGANIC_CITY_NO_FOOD_GROWTH</ModifierId><Name>Amount</Name><Value>-100</Value></Row>
		<Row><ModifierId>CHIP_FAB_PRODUCE_CHIPS</ModifierId><Name>ResourceType</Name><Value>RESOURCE_CHIPS</Value></Row>
		<Row><ModifierId>CHIP_FAB_PRODUCE_CHIPS</ModifierId><Name>Amount</Name><Value>1</Value></Row>
		<Row><ModifierId>ADVANCED_CHIP_FAB_PRODUCE_CHIPS</ModifierId><Name>ResourceType</Name><Value>RESOURCE_CHIPS</Value></Row>
		<Row><ModifierId>ADVANCED_CHIP_FAB_PRODUCE_CHIPS</ModifierId><Name>Amount</Name><Value>2</Value></Row>
		<Row><ModifierId>EXPERT_CHIP_FAB_PRODUCE_CHIPS</ModifierId><Name>ResourceType</Name><Value>RESOURCE_CHIPS</Value></Row>
		<Row><ModifierId>EXPERT_CHIP_FAB_PRODUCE_CHIPS</ModifierId><Name>Amount</Name><Value>2</Value></Row>
		<Row><ModifierId>FUSION_CORE_GENERATE_POWER</ModifierId><Name>Amount</Name><Value>16</Value></Row>
		<Row><ModifierId>FUSION_CORE_GENERATE_POWER</ModifierId><Name>SourceType</Name><Value>FREE_POWER_SOURCE_NUCLEAR</Value></Row>
	</ModifierArguments>

	<BuildingModifiers>
		<Row BuildingType="BUILDING_INORGANIC_CITY"    ModifierId="INORGANIC_CITY_NO_FOOD_GROWTH"/>
		<Row BuildingType="BUILDING_CHIP_FAB"          ModifierId="CHIP_FAB_PRODUCE_CHIPS"/>
		<Row BuildingType="BUILDING_ADVANCED_CHIP_FAB"  ModifierId="ADVANCED_CHIP_FAB_PRODUCE_CHIPS"/>
		<Row BuildingType="BUILDING_EXPERT_CHIP_FAB"    ModifierId="EXPERT_CHIP_FAB_PRODUCE_CHIPS"/>
		<Row BuildingType="BUILDING_FUSION_CORE"        ModifierId="FUSION_CORE_GENERATE_POWER"/>
	</BuildingModifiers>

	<Building_YieldChanges>
		<Row BuildingType="BUILDING_CHIP_FAB"          YieldType="YIELD_PRODUCTION" YieldChange="2"/>
		<Row BuildingType="BUILDING_ADVANCED_CHIP_FAB"  YieldType="YIELD_PRODUCTION" YieldChange="3"/>
		<Row BuildingType="BUILDING_ADVANCED_CHIP_FAB"  YieldType="YIELD_SCIENCE"    YieldChange="1"/>
		<Row BuildingType="BUILDING_EXPERT_CHIP_FAB"    YieldType="YIELD_PRODUCTION" YieldChange="4"/>
		<Row BuildingType="BUILDING_EXPERT_CHIP_FAB"    YieldType="YIELD_SCIENCE"    YieldChange="2"/>
		<Row BuildingType="BUILDING_AI_DIVIDENDS"       YieldType="YIELD_GOLD"       YieldChange="10"/>
		<Row BuildingType="BUILDING_FUSION_CORE"        YieldType="YIELD_SCIENCE"    YieldChange="3"/>
	</Building_YieldChanges>
</GameData>
